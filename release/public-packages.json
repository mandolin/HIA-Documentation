{
  "schemaVersion": "0.1.0-draft",
  "releaseTrain": "public-contract-d2",
  "scope": "@hia-doc",
  "registry": "https://registry.npmjs.org/",
  "runtimeNodeRange": ">=20.19.0",
  "packageManager": "pnpm@10.34.4",
  "firstReleaseDistTag": "latest",
  "publishToolchain": {
    "nodeVersion": "24.x",
    "minimumNodeVersion": "22.14.0",
    "minimumNpmVersion": "11.5.1",
    "packCommand": "pnpm --filter <package> pack",
    "publishCommand": "npm publish <tarball> --access public --provenance",
    "trustedPublishing": {
      "provider": "github-actions",
      "runner": "ubuntu-latest",
      "requiredPermissions": ["contents: read", "id-token: write"]
    }
  },
  "packages": [
    {
      "name": "@hia-doc/core",
      "path": "packages/core",
      "targetVersion": "0.1.0",
      "publishOrder": 10,
      "kind": "owner-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/config",
      "path": "packages/config",
      "targetVersion": "0.1.0",
      "publishOrder": 20,
      "kind": "owner-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/profile",
      "path": "packages/profile",
      "targetVersion": "0.1.0",
      "publishOrder": 20,
      "kind": "owner-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/parser-jsdoc",
      "path": "packages/parser-jsdoc",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "adapter-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/plugin-sdk",
      "path": "packages/plugin-sdk",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "producer-sdk",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/source-linkage",
      "path": "packages/source-linkage",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "owner-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/theme-default",
      "path": "packages/theme-default",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "renderer-asset-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/profiles",
      "path": "packages/profiles",
      "targetVersion": "0.1.0",
      "publishOrder": 40,
      "kind": "distribution",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/renderer-html",
      "path": "packages/renderer-html",
      "targetVersion": "0.1.0",
      "publishOrder": 40,
      "kind": "renderer-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/schemas",
      "path": "packages/schemas",
      "targetVersion": "0.1.0",
      "publishOrder": 50,
      "kind": "distribution",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/lsp",
      "path": "packages/lsp",
      "targetVersion": "0.1.0",
      "publishOrder": 60,
      "kind": "tooling-runtime",
      "releaseStatus": "candidate"
    },
    {
      "name": "@hia-doc/cli",
      "path": "apps/cli",
      "targetVersion": "0.1.0",
      "publishOrder": 70,
      "kind": "tooling-runtime",
      "releaseStatus": "candidate"
    }
  ],
  "excludedPackages": [
    {
      "name": "@hia-doc/vscode-extension",
      "path": "apps/vscode-extension",
      "reason": "VS Code extension packaging uses VSIX/Marketplace release governance, not the npm contract release train."
    }
  ],
  "bootstrapChecklist": [
    "Confirm npm account access and create or claim the @hia-doc organization/scope.",
    "Bootstrap the first @hia-doc package under controlled manual approval if npm requires an existing package before Trusted Publishing can be configured.",
    "Configure npm Trusted Publisher for this GitHub repository and the npm Trusted Publish workflow.",
    "Flip one package at a time from private 0.0.0 to the target version, pack it with pnpm and publish the tarball through npm with provenance.",
    "Run registry clean-install and public schema URL smoke after each publish batch."
  ],
  "postPublishSmoke": [
    "npm view <package>@<targetVersion> version --registry=https://registry.npmjs.org/",
    "npm pack <package>@<targetVersion> --registry=https://registry.npmjs.org/",
    "npm install <package>@<targetVersion> --registry=https://registry.npmjs.org/",
    "node -e \"import('<package>').then(() => console.log('ok'))\""
  ]
}
