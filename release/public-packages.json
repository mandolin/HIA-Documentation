{
  "schemaVersion": "0.1.0-draft",
  "releaseTrain": "trusted-publisher-patch-rehearsal",
  "scope": "@hia-doc",
  "registry": "https://registry.npmjs.org/",
  "runtimeNodeRange": ">=20.19.0",
  "packageManager": "pnpm@10.34.4",
  "firstReleaseDistTag": "latest",
  "publishToolchain": {
    "nodeVersion": "24.x",
    "minimumNodeVersion": "22.14.0",
    "minimumNpmVersion": "11.15.0",
    "packCommand": "pnpm --filter <package> pack",
    "publishCommand": "npm publish <tarball> --access public --provenance",
    "trustedPublishing": {
      "provider": "github-actions",
      "runner": "ubuntu-latest",
      "requiredPermissions": ["contents: read", "id-token: write"]
    }
  },
  "packages": [
    {
      "name": "@hia-doc/core",
      "path": "packages/core",
      "targetVersion": "0.1.0",
      "publishOrder": 10,
      "kind": "owner-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/config",
      "path": "packages/config",
      "targetVersion": "0.1.0",
      "publishOrder": 20,
      "kind": "owner-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/profile",
      "path": "packages/profile",
      "targetVersion": "0.1.0",
      "publishOrder": 20,
      "kind": "owner-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/parser-jsdoc",
      "path": "packages/parser-jsdoc",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "adapter-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/plugin-sdk",
      "path": "packages/plugin-sdk",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "producer-sdk",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/source-linkage",
      "path": "packages/source-linkage",
      "targetVersion": "0.1.0",
      "publishOrder": 30,
      "kind": "owner-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/theme-default",
      "path": "packages/theme-default",
      "targetVersion": "0.1.1",
      "publishOrder": 30,
      "kind": "renderer-asset-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/browser-panel",
      "path": "packages/browser-panel",
      "targetVersion": "0.1.0",
      "publishOrder": 40,
      "kind": "browser-tooling-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/profiles",
      "path": "packages/profiles",
      "targetVersion": "0.1.0",
      "publishOrder": 40,
      "kind": "distribution",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/renderer-html",
      "path": "packages/renderer-html",
      "targetVersion": "0.1.0",
      "publishOrder": 40,
      "kind": "renderer-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/schemas",
      "path": "packages/schemas",
      "targetVersion": "0.1.0",
      "publishOrder": 50,
      "kind": "distribution",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/lsp",
      "path": "packages/lsp",
      "targetVersion": "0.1.0",
      "publishOrder": 60,
      "kind": "tooling-runtime",
      "releaseStatus": "published"
    },
    {
      "name": "@hia-doc/cli",
      "path": "apps/cli",
      "targetVersion": "0.1.0",
      "publishOrder": 70,
      "kind": "tooling-runtime",
      "releaseStatus": "published"
    }
  ],
  "excludedPackages": [
    {
      "name": "@hia-doc/vscode-extension",
      "path": "apps/vscode-extension",
      "reason": "VS Code extension packaging uses VSIX/Marketplace release governance, not the npm contract release train."
    }
  ],
  "bootstrapChecklist": [
    "Confirm npm account access and ownership of the @hia-doc organization/scope.",
    "Commit and push the explicit 0.1.0/public release manifest to mandolin/HIA-Documentation before dispatching the bootstrap workflow.",
    "Create a one-day granular npm token limited to the @hia-doc scope with packages/scopes read-write and Bypass 2FA enabled; store it only as the HIA_NPM_BOOTSTRAP_TOKEN GitHub repository secret.",
    "Dispatch npm-bootstrap-publish.yml on a GitHub-hosted runner with its exact confirmation phrase; it packs and publishes the approved 13-package order with provenance and can resume only when explicitly requested.",
    "After all packages exist, configure npm Trusted Publisher for mandolin/HIA-Documentation and npm-trusted-publish.yml, then delete HIA_NPM_BOOTSTRAP_TOKEN and revoke the temporary npm token.",
    "Set each package to require 2FA and disallow tokens, then run registry clean-install and public schema URL smoke."
  ],
  "postPublishSmoke": [
    "npm view <package>@<targetVersion> version --registry=https://registry.npmjs.org/",
    "npm pack <package>@<targetVersion> --registry=https://registry.npmjs.org/",
    "npm install <package>@<targetVersion> --registry=https://registry.npmjs.org/",
    "node -e \"import('<package>').then(() => console.log('ok'))\""
  ]
}
