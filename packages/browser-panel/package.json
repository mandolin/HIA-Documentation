{
  "name": "@hia-doc/browser-panel",
  "version": "0.0.0",
  "private": true,
  "description": "Static browser panel renderer for HIA source-linked documentation lookup.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandolin/HIA-Documentation.git",
    "directory": "packages/browser-panel"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root ../.. packages/browser-panel/src/index.test.ts"
  },
  "dependencies": {
    "@hia-doc/source-linkage": "workspace:*"
  },
  "sideEffects": false
}
