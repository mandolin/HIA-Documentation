{
  "name": "@hia-doc/lsp",
  "version": "0.0.0",
  "private": true,
  "description": "Language Server Protocol layer for HIA documents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandolin/HIA-Documentation.git",
    "directory": "packages/lsp"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hia-lsp": "./dist/node.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "cd ../.. && vitest run packages/lsp/src"
  },
  "dependencies": {
    "@hia-doc/config": "workspace:*",
    "@hia-doc/core": "workspace:*",
    "@hia-doc/profile": "workspace:*",
    "@hia-doc/source-linkage": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "sideEffects": false
}
