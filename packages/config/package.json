{
  "name": "@hia-doc/config",
  "version": "0.0.0",
  "private": true,
  "description": "Project configuration contract and loader for HIA documentation tools.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run src/**/*.test.ts"
  },
  "dependencies": {
    "@hia-doc/core": "workspace:*"
  },
  "sideEffects": false
}
