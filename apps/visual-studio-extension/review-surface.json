{
  "contract": "hia-visual-studio-review-surface",
  "contractVersion": "0.1.0-draft",
  "status": "input-candidate",
  "surface": {
    "id": "hia-vs-review-tool-window",
    "displayName": "HIA Documentation Review",
    "kind": "tool-window",
    "primaryRequest": "hia/documentationEditProposals",
    "payloadContract": "hia-documentation-review-payload@0.1.0-draft",
    "editCandidateContract": "hia-documentation-edit-candidate@0.1.0-draft",
    "editDiffPreviewContract": "hia-documentation-edit-diff-preview@0.1.0-draft",
    "editApplyPreflightContract": "hia-documentation-edit-apply-preflight@0.1.0-draft",
    "providerAugmentationContract": "hia-provider-review-payload-augmentation@0.1.0-draft",
    "hostResultContract": "hia-lsp-host-result@0.1.0-draft"
  },
  "providerReview": {
    "status": "input-ready",
    "inputMode": "review-payload-augmentation-only",
    "checkedApplyAvailable": false,
    "externalProviderApiKeyRequired": false,
    "externalProviderNetworkAllowed": false,
    "workspaceWriteAvailable": false,
    "targetRepositoryMutation": false,
    "requiredFields": [
      "providerAugmentation.contract",
      "providerAugmentation.contractVersion",
      "providerAugmentation.provider",
      "providerAugmentation.status",
      "providerAugmentation.draftOutputs",
      "providerAugmentation.reviewMetadata",
      "providerAugmentation.refusalOutputs",
      "providerAugmentation.actionPolicy",
      "providerAugmentation.privacy"
    ]
  },
  "providerReviewPanel": {
    "contract": "hia-visual-studio-provider-review-linkage-panel",
    "status": "input-ready",
    "inputMode": "provider-result-refusal-review-only",
    "providerIdSource": "providerAugmentation.provider.id",
    "resultTaxonomyKindCount": 5,
    "blockedProviderReviewShapeAccepted": true,
    "refusalResultVisible": true,
    "reviewOnlyOutputRequired": true,
    "requiresHumanReview": true,
    "targetOwnerHandoffVisible": true,
    "directApplyAllowed": false,
    "workspaceWriteAvailable": false,
    "targetRepositoryMutation": false,
    "providerNetworkExecuted": false,
    "sourcesContentPolicy": "none",
    "requiredFields": [
      "providerAugmentation.provider.id",
      "providerAugmentation.status",
      "providerAugmentation.reviewMetadata",
      "providerAugmentation.refusalOutputs",
      "providerReviewPanel.resultTaxonomyKindCount",
      "providerReviewPanel.reviewOnlyOutputRequired"
    ]
  },
  "applyPreview": {
    "status": "input-ready",
    "inputMode": "preflight-preview-only",
    "checkedApplyAvailable": false,
    "hostFileReadAvailable": false,
    "workspaceWriteAvailable": false,
    "targetRepositoryMutation": false,
    "requiredFields": [
      "item.editCandidate.applyPreflight.status",
      "item.editCandidate.applyPreflight.conflictStatus",
      "item.editCandidate.applyPreflight.requiresFileRead",
      "item.editCandidate.applyPreflight.requiresConflictCheck",
      "item.editCandidate.applyPreflight.targetFiles",
      "item.editCandidate.applyPreflight.rollback"
    ]
  },
  "checkedApplyConfirmation": {
    "status": "input-ready",
    "inputMode": "confirmation-preview-only",
    "checkedApplyAvailable": false,
    "workspaceWriteAvailable": false,
    "targetRepositoryMutation": false,
    "directApplyAvailable": false,
    "requiredFields": [
      "checkedApplyConfirmation.status",
      "checkedApplyConfirmation.confirmationChoiceCount",
      "checkedApplyConfirmation.confirmationReportCount",
      "checkedApplyConfirmation.sandboxApplySuccessCount",
      "checkedApplyConfirmation.realGuiManualEvidenceRequired"
    ]
  },
  "targetCollaboration": {
    "status": "input-ready",
    "inputMode": "target-owner-flow-only",
    "targetOwnerActionRequiredForWrite": true,
    "hiaOwnedTargetRepositoryMutationAllowed": false,
    "actualTargetBranchCreated": false,
    "actualPullRequestCreated": false,
    "targetRepositoryMutationCount": 0,
    "requiredFields": [
      "targetCollaboration.status",
      "targetCollaboration.collaborationModeCount",
      "targetCollaboration.flowStateCount",
      "targetCollaboration.targetOwnerActionRequiredForWrite",
      "targetCollaboration.hiaOwnedTargetRepositoryMutationAllowed"
    ]
  },
  "hostApplyUx": {
    "contract": "hia-visual-studio-host-apply-ux-summary",
    "status": "input-ready",
    "inputMode": "host-owned-apply-ux-intake-only",
    "surface": "visual-studio-review-tool-window",
    "surfaceContract": "hia-wp43-host-owned-apply-ux-intake-evidence@0.1.0-draft",
    "vscodeBaselineContract": "hia-wp43-vscode-host-ux-surface-evidence@0.1.0-draft",
    "uxRequirementRefCount": 8,
    "providerReviewLinkageVisible": true,
    "targetOwnerEvidenceVisible": true,
    "deferredGateVisible": true,
    "checkedApplyWriteEnabled": false,
    "workspaceWriteAvailable": false,
    "targetRepositoryMutation": false,
    "directEditObjectProduced": false,
    "providerNetworkExecuted": false,
    "targetCommandsExecutedByHia": false,
    "actualRuntimeCaptureExecuted": false,
    "hostEditorApiCalled": false,
    "sourcesContentPolicy": "none",
    "requiredFields": [
      "hostApplyUx.status",
      "hostApplyUx.uxRequirementRefCount",
      "hostApplyUx.providerReviewLinkageVisible",
      "hostApplyUx.targetOwnerEvidenceVisible",
      "hostApplyUx.deferredGateVisible",
      "hostApplyUx.checkedApplyWriteEnabled"
    ]
  },
  "views": [
    {
      "id": "review-list",
      "title": "Review List",
      "purpose": "Show proposal status, risk, target label and locale-quality counts without exposing source content.",
      "requiredFields": [
        "item.id",
        "item.kind",
        "item.status",
        "item.risk",
        "item.target.label",
        "item.actionHints"
      ]
    },
    {
      "id": "review-detail",
      "title": "Review Detail",
      "purpose": "Show proposal text, draft text and AI context reference for human review.",
      "requiredFields": [
        "item.proposalId",
        "item.proposal.summary",
        "item.draft.text",
        "item.aiContextRef"
      ]
    },
    {
      "id": "provider-review",
      "title": "Provider Review",
      "purpose": "Show provider origin, draft outputs, review metadata, quality signals and refusal state without granting apply or write authority.",
      "requiredFields": [
        "providerAugmentation.provider.id",
        "providerAugmentation.provider.runtimeKind",
        "providerAugmentation.draftOutputs",
        "providerAugmentation.reviewMetadata",
        "providerAugmentation.refusalOutputs",
        "providerAugmentation.actionPolicy.directApplyAllowed",
        "providerAugmentation.privacy.sourcesContentPolicy"
      ]
    },
    {
      "id": "provider-review-linkage",
      "title": "Provider Review Linkage",
      "purpose": "Show provider result/refusal taxonomy, blocked shape, review-only output boundary and target-owner handoff state.",
      "requiredFields": [
        "providerReviewPanel.status",
        "providerReviewPanel.resultTaxonomyKindCount",
        "providerReviewPanel.blockedProviderReviewShapeAccepted",
        "providerReviewPanel.refusalResultVisible",
        "providerReviewPanel.reviewOnlyOutputRequired",
        "providerReviewPanel.targetOwnerHandoffVisible"
      ]
    },
    {
      "id": "candidate-preview",
      "title": "Edit Candidate Preview",
      "purpose": "Show read-only edit candidate metadata before any future apply workflow is designed.",
      "requiredFields": [
        "item.editCandidate.contract",
        "item.editCandidate.status",
        "item.editCandidate.target",
        "item.editCandidate.preview",
        "item.editCandidate.diffPreview.status",
        "item.editCandidate.diffPreview.operations",
        "item.editCandidate.diffPreview.safety",
        "item.editCandidate.applyPreflight.status",
        "item.editCandidate.applyPreflight.conflictStatus",
        "item.editCandidate.applyPreflight.rollback"
      ]
    },
    {
      "id": "checked-apply-confirmation",
      "title": "Checked Apply Confirmation",
      "purpose": "Show checked apply confirmation gates and keep apply disabled until explicit host-owned approval exists.",
      "requiredFields": [
        "checkedApplyConfirmation.status",
        "checkedApplyConfirmation.confirmationChoiceCount",
        "checkedApplyConfirmation.confirmationReportCount",
        "checkedApplyConfirmation.workspaceWriteAllowed",
        "checkedApplyConfirmation.targetRepositoryMutation"
      ]
    },
    {
      "id": "target-collaboration",
      "title": "Target Collaboration",
      "purpose": "Show target-owned sandbox, branch and pull request flow without granting HIA target repository write authority.",
      "requiredFields": [
        "targetCollaboration.status",
        "targetCollaboration.collaborationModeCount",
        "targetCollaboration.flowStateCount",
        "targetCollaboration.targetOwnerActionRequiredForWrite",
        "targetCollaboration.hiaOwnedTargetRepositoryMutationAllowed"
      ]
    },
    {
      "id": "host-apply-ux",
      "title": "Host Apply UX",
      "purpose": "Show W-P43 host-owned apply UX requirements, provider review linkage, target-owner evidence and deferred gates without granting write authority.",
      "requiredFields": [
        "hostApplyUx.status",
        "hostApplyUx.uxRequirementRefCount",
        "hostApplyUx.providerReviewLinkageVisible",
        "hostApplyUx.targetOwnerEvidenceVisible",
        "hostApplyUx.deferredGateVisible",
        "hostApplyUx.checkedApplyWriteEnabled"
      ]
    }
  ],
  "actions": [
    {
      "id": "copy-draft",
      "hostAction": "Copy selected draft text to clipboard after human review.",
      "mutatesTargetRepository": false,
      "requiresHumanReview": true
    },
    {
      "id": "copy-proposal-id",
      "hostAction": "Copy selected proposal id for issue, PR or AI handoff notes.",
      "mutatesTargetRepository": false,
      "requiresHumanReview": false
    },
    {
      "id": "open-context",
      "hostAction": "Open a workspace-relative source, generated artifact or documentation entry through structured open requests.",
      "mutatesTargetRepository": false,
      "requiresHumanReview": false
    },
    {
      "id": "apply-candidate",
      "hostAction": "Disabled until checked apply confirmation exists.",
      "available": false,
      "mutatesTargetRepository": false,
      "requiresHumanReview": true
    }
  ],
  "languageAuthoringHints": {
    "canonicalMarkers": [
      "@lang",
      "<lang>",
      "<l>"
    ],
    "dotnetXmlMarkers": [
      "<lang>",
      "<l>"
    ],
    "sourceDocumentTruth": "HiaI18nModel.fields",
    "notes": "Visual Studio should display language-marker completion and hover data from @hia-doc/lsp instead of inventing host-only markers."
  },
  "targetScenarios": [
    {
      "id": "hia-aspnetportal",
      "purpose": "Review DotNetDoc and ASP.NET documentation proposals in Visual Studio without modifying the target repository.",
      "sourcePolicy": "workspace-relative-only",
      "targetRepositoryPolicy": "central-notify-read-only"
    }
  ],
  "privacy": {
    "allowAbsolutePathsInHostPayload": false,
    "allowTargetRepositoryMutation": false,
    "embedsSourcesContent": false,
    "allowsAutomaticApply": false,
    "requiresHumanReviewForEditProposals": true
  }
}
