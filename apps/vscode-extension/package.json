{
  "name": "@hia-doc/vscode-extension",
  "version": "0.0.0",
  "private": true,
  "displayName": "HIA Documentation",
  "description": "VS Code extension shell for the HIA documentation engineering system.",
  "publisher": "mandolin",
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:hia",
    "onCommand:hia.showOutput",
    "onCommand:hia.buildDocs",
    "onCommand:hia.openPreview",
    "onCommand:hia.openSourceLinkage",
    "onCommand:hia.openProjectRelations",
    "onCommand:hia.validateWorkspace",
    "onCommand:hia.openRelatedLocation",
    "onCommand:hia.showResourceAction",
    "onCommand:hia.copyResourceKey",
    "onCommand:hia.reviewDocumentationProposals",
    "onCommand:hia.showCheckedApplySandboxConfirmation",
    "onCommand:hia.showHostApplyUxIntake",
    "workspaceContains:**/*.hia.json",
    "workspaceContains:**/project-index.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "hia",
        "aliases": ["HIA Document", "hia"],
        "extensions": [".hia.json"],
        "configuration": "./language-configuration.json"
      }
    ],
    "commands": [
      {
        "command": "hia.showOutput",
        "title": "HIA: Show Output"
      },
      {
        "command": "hia.buildDocs",
        "title": "HIA: Build Docs"
      },
      {
        "command": "hia.openPreview",
        "title": "HIA: Open Preview"
      },
      {
        "command": "hia.openSourceLinkage",
        "title": "HIA: Open Source Linkage"
      },
      {
        "command": "hia.openProjectRelations",
        "title": "HIA: Open Project Relations"
      },
      {
        "command": "hia.validateWorkspace",
        "title": "HIA: Validate Workspace"
      },
      {
        "command": "hia.reviewDocumentationProposals",
        "title": "HIA: Review Documentation Proposals"
      },
      {
        "command": "hia.showCheckedApplySandboxConfirmation",
        "title": "HIA: Show Checked Apply Sandbox Confirmation"
      },
      {
        "command": "hia.showHostApplyUxIntake",
        "title": "HIA: Show Host Apply UX Intake"
      }
    ],
    "configuration": {
      "title": "HIA Documentation",
      "properties": {
        "hia.server.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Controls tracing for the HIA language server."
        },
        "hia.build.config": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative HIA config JSON file passed to `hia docs build --config`."
        },
        "hia.build.input": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative HIA document JSON file passed to `hia docs build --input`."
        },
        "hia.build.jsdocIntegration": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative JSDoc HIA Integration JSON file passed to `hia docs build --jsdoc-integration`."
        },
        "hia.build.projectManifest": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative project docs manifest JSON file passed to `hia docs build --project-manifest`."
        },
        "hia.build.out": {
          "type": "string",
          "default": "dist/docs",
          "description": "Workspace-relative output directory passed to `hia docs build --out`."
        },
        "hia.build.locale": {
          "type": "string",
          "default": "",
          "description": "Initial rendered locale passed to `hia docs build --locale`."
        },
        "hia.build.manifest": {
          "type": "string",
          "default": "hia-manifest.json",
          "description": "Output manifest path inside hia.build.out, passed to `hia docs build --manifest` and read by HIA: Open Preview."
        },
        "hia.preview.path": {
          "type": "string",
          "default": "dist/docs/index.html",
          "description": "Workspace-relative or absolute HTML file opened by HIA: Open Preview."
        }
      }
    }
  },
  "files": ["dist", "README.md", "language-configuration.json", "package.json"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "cd ../.. && vitest run apps/vscode-extension/src/config.test.ts apps/vscode-extension/src/source-linkage.test.ts apps/vscode-extension/src/project-relations.test.ts"
  },
  "dependencies": {
    "@hia-doc/lsp": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.92.0"
  },
  "sideEffects": false
}
