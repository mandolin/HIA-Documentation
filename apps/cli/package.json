{
  "name": "@hia-doc/cli",
  "version": "0.0.0",
  "private": true,
  "description": "Command line entry for the HIA documentation system.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandolin/HIA-Documentation.git",
    "directory": "apps/cli"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "type": "module",
  "bin": {
    "hia": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run src/**/*.test.ts"
  },
  "dependencies": {
    "@hia-doc/config": "workspace:*",
    "@hia-doc/core": "workspace:*",
    "@hia-doc/parser-jsdoc": "workspace:*",
    "@hia-doc/plugin-sdk": "workspace:*",
    "@hia-doc/profile": "workspace:*",
    "@hia-doc/renderer-html": "workspace:*",
    "@hia-doc/source-linkage": "workspace:*"
  }
}
