{
  "name": "hia-documentation-sys-main",
  "version": "0.0.0",
  "private": true,
  "description": "Core monorepo for the HIA documentation engineering system.",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "check": "pnpm run build && pnpm run test:unit && pnpm run test:e2e",
    "dev:cli": "pnpm --filter @hia-doc/cli dev",
    "governance:check": "node scripts/check-example-fixture-governance.mjs",
    "hia": "node apps/cli/dist/index.js",
    "license:audit": "node scripts/check-dependency-license-audit.mjs",
    "release:gate": "pnpm run check && pnpm run schema:check && node scripts/release-gate-jsdoc-smoke.mjs && pnpm run governance:check && pnpm run license:audit",
    "schema:check": "node scripts/check-schema-contracts.mjs",
    "smoke:published-jsdoc": "pnpm run build && node scripts/published-jsdoc-smoke.mjs",
    "test": "pnpm run check",
    "test:e2e": "vitest run tests",
    "test:unit": "vitest run --exclude tests/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "2.1.9"
  }
}
