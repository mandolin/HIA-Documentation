{
  "name": "hia-documentation-sys-main",
  "version": "0.0.0",
  "private": true,
  "description": "Core monorepo for the HIA documentation engineering system.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "tsc -b --pretty false",
    "check": "pnpm run build && pnpm run test:unit && pnpm run test:e2e",
    "dev:cli": "pnpm --filter @hia-doc/cli dev",
    "distribution:check": "node scripts/check-distribution-readiness.mjs && node scripts/check-public-release-plan.mjs",
    "governance:check": "node scripts/check-example-fixture-governance.mjs",
    "hia": "node apps/cli/dist/index.js",
    "license:audit": "node scripts/check-dependency-license-audit.mjs",
    "release:postpublish:smoke": "node scripts/post-publish-smoke.mjs",
    "release:registry:check": "node scripts/check-public-registry-status.mjs",
    "release:registry:preflight": "node scripts/check-public-registry-status.mjs --prepublish",
    "release:gate": "pnpm run check && pnpm run schema:check && pnpm run schema:site && pnpm run distribution:check && pnpm run reference:definition:check && node scripts/release-gate-jsdoc-smoke.mjs && pnpm run governance:check && pnpm run license:audit",
    "reference:build": "node scripts/build-public-reference.mjs",
    "reference:check": "node scripts/check-public-reference-build.mjs",
    "reference:definition:check": "node scripts/build-public-reference.mjs --check-definition",
    "reference:pages": "node scripts/build-reference-pages.mjs",
    "reference:pages:check": "node scripts/check-reference-pages.mjs",
    "reference:pages:online": "node scripts/check-reference-pages-online.mjs",
    "schema:check": "node scripts/check-schema-contracts.mjs",
    "schema:site": "node scripts/build-schema-pages.mjs",
    "schema:site:online": "node scripts/check-schema-pages-online.mjs",
    "schema:sync": "pnpm run build && pnpm --filter @hia-doc/schemas sync",
    "smoke:published-jsdoc": "pnpm run build && node scripts/published-jsdoc-smoke.mjs",
    "test": "pnpm run check",
    "test:e2e": "vitest run tests",
    "test:unit": "vitest run --exclude tests/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "2.1.9"
  }
}
